# ============================================================
# ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE
# ============================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores reais no arquivo .env
#   3. NUNCA comite o .env no Git (já está no .gitignore)
# ============================================================

# Chave de API da fonte de dados escolhida pelo grupo
API_KEY=sua_chave_aqui

# URL base da API (ex: Portal da Transparência, IBGE, etc.)
API_BASE_URL=https://api.exemplo.gov.br/v1

# Configurações opcionais do banco (se necessário)
# DB_PATH=data/analytics.duckdb
